# syntax=docker/dockerfile:1.4
#
# Multi-stage Dockerfile for the MCP server (standalone build).
#
# The vector store (ChromaDB index) is BUILT at image-build time from the
# source k8s_docs.json document corpus. This keeps the git repo small
# (~250 KB JSON vs ~50 MB ChromaDB binary files) while ensuring the image
# is self-contained and reproducible.

# ---------- Stage 1: builder ----------
FROM python:3.11-slim AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY docker/requirements.mcp.txt .
RUN pip install --no-cache-dir --user -r requirements.mcp.txt

# Build the ChromaDB index from the source docs
# This downloads the sentence-transformers model and computes embeddings.
ENV PATH=/root/.local/bin:$PATH
COPY scripts/build_vector_store.py /build/scripts/
COPY data/k8s_docs.json /build/data/
WORKDIR /build
RUN python scripts/build_vector_store.py


# ---------- Stage 2: runtime ----------
FROM python:3.11-slim AS runtime

RUN useradd -m -u 1000 appuser

WORKDIR /app

COPY --from=builder /root/.local /home/appuser/.local
RUN chown -R appuser:appuser /home/appuser/.local

# Copy MCP server code and the freshly-built vector store
COPY --chown=appuser:appuser mcp_server/ ./mcp_server/
COPY --from=builder --chown=appuser:appuser /build/data/chroma/ ./data/chroma/
COPY --chown=appuser:appuser data/k8s_docs.json ./data/

USER appuser
ENV PATH=/home/appuser/.local/bin:$PATH
ENV PYTHONUNBUFFERED=1
ENV HF_HOME=/home/appuser/.cache/huggingface

CMD ["python", "mcp_server/server.py"]